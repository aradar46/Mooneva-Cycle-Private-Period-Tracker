<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Neumorphic background with gradient -->
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#F5F7FA"
        android:centerColor="#F0F2F5"
        android:endColor="#E8EAED" />

    <!-- Rounded corners -->
    <corners android:radius="20dp" />

    <!-- Subtle stroke for depth -->
    <stroke
        android:width="1dp"
        android:color="#E2E8F0" />

    <!-- Padding -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />

</shape>
